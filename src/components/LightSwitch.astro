---
// LightSwitch component for dark/light mode toggle
---

<div class="lightswitch">
    <img
        class="lightswitch-img"
        src="/img/off.jpg"
        alt="Dark Mode"
    />
</div>

<script>
    // Dark mode toggle – syncs all lightswitch images on the page
    let darkMode = true;

    function updateAllLightSwitches() {
        document.body.classList.toggle('dark', darkMode);
        document.querySelectorAll('.lightswitch-img').forEach((img) => {
            img.src = darkMode ? '/img/off.jpg' : '/img/on.jpg';
            img.alt = darkMode ? 'Dark Mode' : 'Light Mode';
        });
    }

    function playSwitchSound() {
        const sound = new Audio(darkMode ? '/img/lightOff.mp3' : '/img/lightOn.mp3');
        sound.volume = 1;
        sound.play().catch(() => {});
    }

    function toggleDarkMode() {
        darkMode = !darkMode;
        updateAllLightSwitches();
        localStorage.setItem('darkMode', darkMode.toString());
        playSwitchSound();
    }

    document.addEventListener('DOMContentLoaded', () => {
        const savedMode = localStorage.getItem('darkMode');
        if (savedMode !== null) {
            darkMode = savedMode === 'true';
        }
        updateAllLightSwitches();

        document.querySelectorAll('.lightswitch-img').forEach((img) => {
            img.addEventListener('click', toggleDarkMode);
        });
    });
</script>
