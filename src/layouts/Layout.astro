---
export interface Props {
	title?: string;
	description?: string;
}

const { title = "BCD-ROM", description = "Bradley CD AKA BCD-ROM is a creative technologist and music producer based in Brooklyn and this is his creative portfolio!" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#000000" />
		<title>{title}</title>
	</head>
	<body>
		<div class="cd-section" id="cd-section">
			<div class="cd-section__content">
				<slot />
			</div>
		</div>
	</body>
</html>

<style is:global>



	@import url('https://fonts.googleapis.com/css2?family=Sorts+Mill+Goudy&display=swap');

	@font-face {
		font-family: 'ManifontGroteskBook';
		src: url('/fonts/ManifontGroteskBook.ttf') format('truetype');
		font-weight: 1;
	}

	html {
		scroll-behavior: smooth;
		margin: 0;
		width: 100%;
		height: 100%;
	}

	body {
		margin: 0;
		font-family: 'ManifontGroteskBook', serif;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		background-color: white;
		font-weight: lighter !important;
		color: black;
		width: 100%;
		height: 100%;
		transition: background-color 0.3s ease, color 0.3s ease;
	}

	body.dark {
		background-color: black;
		color: white;
	}
	

	.cd-section {
		position: relative;
		min-height: 100%;
		overflow: visible;
	}

	.cd-section__content {
		position: relative;
		z-index: 1;
	}

	/* CD reflection: sits on top of content so it's visible, pointer-events: none so clicks pass through */
	.cd-section::before {
		content: "";
		position: fixed;
		top: 50%;
		left: 50%;
		width: 200vmax;
		height: 200vmax;
		margin-left: -100vmax;
		margin-top: -100vmax;
		pointer-events: none;
		opacity: 0;
		z-index: 9999;

		/* rainbow spectrum - CD prism reflection */
		background: radial-gradient(
			ellipse 70% 40% at center,
			rgba(255, 0, 0, 0.9),
			rgba(255, 130, 0, 0.9),
			rgba(255, 255, 0, 0.9),
			rgba(0, 255, 100, 0.9),
			rgba(0, 200, 255, 0.9),
			rgba(100, 100, 255, 0.9),
			rgba(200, 0, 255, 0.9),
			rgba(255, 0, 100, 0.9)
		);

		filter: blur(60px) saturate(180%);

		/* overlay = visible on both light and dark; use screen for a softer "light" look */
		mix-blend-mode: screen;

		/* thin band - the rainbow strip that sweeps */
		mask-image: linear-gradient(
			110deg,
			transparent 40%,
			black 47%,
			black 53%,
			transparent 60%
		);
		-webkit-mask-image: linear-gradient(
			110deg,
			transparent 40%,
			black 47%,
			black 53%,
			transparent 60%
		);

		transform: translateX(-150%) rotate(10deg);
		transition: transform 1.8s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.5s ease;
	}

	.cd-section.active::before {
		opacity: 0.7;
		transform: translateX(150%) rotate(10deg);
	}

	body.dark .cd-section.active::before {
		opacity: 0.85;
		mix-blend-mode: screen;
	}

	h1, h2, h3 {
		font-weight: lighter;
	}

	h5 {
		font-weight: 100;
	}

	.App {
		text-align: center;
	}

	.flexyyy {
		display: flex;
		width: 100%;
		justify-content: center;
		align-items: center;
	}

	.container {
		padding: 10%;
		padding-top: 0;
		max-width: 1500px;
		margin: 0 auto;
		padding-bottom: 20px;
		text-align: left;
	}

	.lightswitch {
		width: 100px;
		cursor: pointer;
		width: 250px;
		margin: auto;
		box-sizing: border-box;
		padding: 75px;
		background: transparent;
		background-color: transparent;
	}

	.lightswitch img {
		width: 100%;
		-webkit-tap-highlight-color: transparent;
	}

	/* Bottom light switch: hidden on desktop, shown on mobile (see media query) */
	.lightswitch-bottom {
		display: none;
		background: transparent;
		background-color: transparent;
	}

	nav {
		flex-grow: 1;
	}

	nav ul {
		list-style: none;
		display: flex;
		justify-content: space-around;
		padding: 0;
		max-width: 500px;
		margin: auto;
	}

	nav li {
		margin: 0 10px;
	}

	nav a {
		font-size: 1.5em;
		text-decoration: none;
		transition: color 0.3s;
		position: relative;
		color: black;
		border-bottom: 2px solid transparent;
	}

	nav a:hover {
		color: #808080 !important;
		transform: scale(1.1);
	}

	.dark nav a {
		color: white;
	}

	@media (max-width: 768px) {
		nav {
			width: 100%;
		}

		/* Light switch: hide in header on mobile */
		.flexyyy .lightswitch {
			display: none;
		}

		/* Light switch at bottom of page (in document flow) – visible only on mobile */
		.lightswitch-bottom {
			display: flex !important;
			justify-content: center;
			align-items: center;
			padding: 24px 16px;
			width: 100%;
			box-sizing: border-box;
			background: transparent !important;
			background-color: transparent !important;
		}

		.lightswitch-bottom .lightswitch {
			padding: 0;
			margin: 0;
			width: auto;
			background: transparent !important;
			background-color: transparent !important;
		}

		.lightswitch-bottom .lightswitch img {
			max-width: 120px;
			width: auto;
			height: auto;
			-webkit-tap-highlight-color: transparent;
		}

		nav li {
			margin: 10px 0;
		}

		.container {
			padding: 20px;
		}

		canvas {
			width: 175px !important;
			height: 175px !important;
		}

		.flexyyy {
			flex-direction: column;
		}

		.phoneShrink {
			font-size: 1.2em;
		}
	}
</style>

<script>
	// Trigger CD reflection sweep on load and when user scrolls (e.g. back to top)
	function runCdSweep() {
		const section = document.getElementById('cd-section');
		if (!section) return;
		section.classList.remove('active');
		section.offsetHeight;
		section.classList.add('active');
		setTimeout(() => section.classList.remove('active'), 2000);
	}

	function initCdReflection() {
		const section = document.getElementById('cd-section');
		if (!section) return;

		// Run once on load
		setTimeout(runCdSweep, 300);

		// Trigger when user scrolls back near the top
		const TOP_THRESHOLD = 180;
		const COOLDOWN_MS = 3500;
		let lastSweep = 0;
		let wasPastTop = false;

		function onScroll() {
			const y = window.scrollY ?? document.documentElement.scrollTop;
			if (y > TOP_THRESHOLD) wasPastTop = true;
			if (y <= TOP_THRESHOLD && wasPastTop && Date.now() - lastSweep > COOLDOWN_MS) {
				wasPastTop = false;
				lastSweep = Date.now();
				runCdSweep();
			}
		}

		window.addEventListener('scroll', onScroll, { passive: true });
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initCdReflection);
	} else {
		initCdReflection();
	}
</script>
